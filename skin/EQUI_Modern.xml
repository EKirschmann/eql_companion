<?xml version="1.0" encoding="us-ascii"?>
<!-- Modern Overhaul - shared "Clean dark flat" definitions.
     Self-contained additive layer: custom textures, gauge/border animations,
     and a glass window template. Referenced by rebuilt window files.
     Included from EQUI.xml AFTER EQUI_Templates.xml / EQUI_Animations.xml. -->
<XML ID="EQInterfaceDefinitionLanguage">
	<Schema xmlns="EverQuestData" xmlns:dt="EverQuestDataTypes" />

	<!-- ============ Textures ============ -->
	<TextureInfo item="modern_glass.tga">
		<Size><CX>64</CX><CY>64</CY></Size>
	</TextureInfo>
	<TextureInfo item="modern_atlas.tga">
		<Size><CX>64</CX><CY>64</CY></Size>
	</TextureInfo>

	<!-- ============ Gauge animations (flat) ============ -->
	<!-- WHITE swatch: tinted by each gauge's <FillTint> -->
	<Ui2DAnimation item="A_ModGaugeFill">
		<Cycle>true</Cycle>
		<Frames>
			<Texture>modern_atlas.tga</Texture>
			<Location><X>18</X><Y>2</Y></Location>
			<Size><CX>12</CX><CY>12</CY></Size>
			<Hotspot><X>0</X><Y>0</Y></Hotspot>
			<Duration>1000</Duration>
		</Frames>
	</Ui2DAnimation>
	<!-- Dark empty track -->
	<Ui2DAnimation item="A_ModGaugeBg">
		<Cycle>true</Cycle>
		<Frames>
			<Texture>modern_atlas.tga</Texture>
			<Location><X>34</X><Y>2</Y></Location>
			<Size><CX>12</CX><CY>12</CY></Size>
			<Hotspot><X>0</X><Y>0</Y></Hotspot>
			<Duration>1000</Duration>
		</Frames>
	</Ui2DAnimation>
	<!-- Fully transparent: square gauge ends (no chunky end caps) -->
	<Ui2DAnimation item="A_ModClear">
		<Cycle>true</Cycle>
		<Frames>
			<Texture>modern_atlas.tga</Texture>
			<Location><X>50</X><Y>2</Y></Location>
			<Size><CX>12</CX><CY>12</CY></Size>
			<Hotspot><X>0</X><Y>0</Y></Hotspot>
			<Duration>1000</Duration>
		</Frames>
	</Ui2DAnimation>

