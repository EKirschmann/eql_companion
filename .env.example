# Copy to .env and adjust. Every field has a working default.

# --- Where your EQL combat logs live (REQUIRED to adjust on most installs)
EQL_LOG_DIR=G:\Daybreak Game Company\Installed Games\EverQuest Legends\Logs
# EQL_LOG_PATH=            # full-path override (wins over the dir scan)
# EQL_CHARACTER_NAME=      # prefer this character; else most recent log

# --- LLM for the Advisor/Companion (all optional — the app runs without one;
#     switch at runtime in the Advisor tab's Counsel selector)
LLM_PROVIDER=none          # none | lmstudio | openai | custom | anthropic | local
MODEL=                     # lmstudio/local model id (as LM Studio/Ollama shows it)
OPENAI_API_KEY=
OPENAI_MODEL=o3
# Any OpenAI-compatible endpoint (Groq, OpenRouter, Gemini compat, LAN box).
# Setting the base URL adds a "Custom" option to the Counsel selector.
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_MODEL=
ANTHROPIC_API_KEY=

# --- EQL MCP server (OPTIONAL: structured spell/AA data; wiki falls back to
#     plain HTTP without it)
# git clone https://github.com/ArtSabintsev/everquest-legends-mcp
# cd everquest-legends-mcp && npm install
MCP_ENABLED=true
MCP_SERVER_DIR=

# --- App
DATABASE_URL=sqlite:///./data/companion.db
FRONTEND_ORIGIN=http://localhost:3000
