# API Keys (optional -- only needed for LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# LLM provider: anthropic | openai | lmstudio | local
# lmstudio: enable LM Studio's local server (Developer tab) and set MODEL to
# the model identifier LM Studio shows (JIT loading gives load-on-demand).
LLM_PROVIDER=lmstudio
MODEL=qwen/qwen3-4b-2507

# EQL MCP server (cloned + built; the backend launches it over stdio)
# git clone https://github.com/Sergeantfirstclassvincetoxicumnegrum35/everquest-legends-mcp
# cd everquest-legends-mcp && npm install
MCP_ENABLED=true
MCP_SERVER_DIR=G:\projects\everquest-legends-mcp

# EQL Log Path (defaults are set in backend/config.py)
# EQL_LOG_PATH=
# EQL_CHARACTER_NAME=

# App Settings
DATABASE_URL=sqlite:///./data/companion.db
ENVIRONMENT=development
DEBUG=true