<?xml version = "1.0"?>
<XML ID = "EQInterfaceDefinitionLanguage">
	<Schema xmlns = "EverQuestData" xmlns:dt = "EverQuestDataTypes"/>
<!-- Action Buttons -->
	<Button item = "NR_YESNO_YesButton">
		<ScreenID>NR_YesButton</ScreenID>
		<Font>4</Font>
		<RelativePosition>true</RelativePosition>
		<Location>
			<X>305</X>
			<Y>195</Y>
		</Location>
		<Size>
			<CX>115</CX>
			<CY>25</CY>
		</Size>
		<TooltipReference>Click to proceed.</TooltipReference>
		<Style_Checkbox>false</Style_Checkbox>
		<Text>Submit</Text>
		<ButtonDrawTemplate>
			<Normal>A_EQLS_SmallBtnNormal</Normal>
			<Pressed>A_EQLS_SmallBtnPressed</Pressed>
			<Flyby>A_EQLS_SmallBtnHover</Flyby>
			<Disabled>A_EQLS_SmallBtnDisabled</Disabled>
			<PressedFlyby>A_EQLS_SmallBtnPressedHover</PressedFlyby>
		</ButtonDrawTemplate>
	</Button>
	<Button item = "NR_YESNO_NoButton">
		<ScreenID>NR_NoButton</ScreenID>
		<Font>4</Font>
		<RelativePosition>true</RelativePosition>
		<Location>
			<X>2</X>
			<Y>195</Y>
		</Location>
		<Size>
			<CX>115</CX>
			<CY>25</CY>
		</Size>
		<TooltipReference>Click to cancel.</TooltipReference>
		<Style_Checkbox>false</Style_Checkbox>
		<Text>Skip</Text>
		<ButtonDrawTemplate>
			<Normal>A_EQLS_SmallBtnNormal</Normal>
			<Pressed>A_EQLS_SmallBtnPressed</Pressed>
			<Flyby>A_EQLS_SmallBtnHover</Flyby>
			<Disabled>A_EQLS_SmallBtnDisabled</Disabled>
			<PressedFlyby>A_EQLS_SmallBtnPressedHover</PressedFlyby>
		</ButtonDrawTemplate>
	</Button>
	<STMLbox item = "NR_YESNO_Display">
		<ScreenID>Display</ScreenID>
		<DrawTemplate>WDT_DarkStone</DrawTemplate>
		<RelativePosition>true</RelativePosition>
		<Style_VScroll>true</Style_VScroll>
		<AutoStretch>true</AutoStretch>
		<LeftAnchorOffset>2</LeftAnchorOffset>
		<TopAnchorOffset>2</TopAnchorOffset>
		<RightAnchorOffset>2</RightAnchorOffset>
		<BottomAnchorOffset>75</BottomAnchorOffset>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<Style_Border>true</Style_Border>
	</STMLbox>
	<Editbox item = "NR_Name">
		<ScreenID>NR_Name</ScreenID>
		<Font>3</Font>
		<DrawTemplate>WDT_DarkStone</DrawTemplate>
		<Style_Border>true</Style_Border>
		<RelativePosition>true</RelativePosition>
		<Location>
			<X>2</X>
			<Y>155</Y>
		</Location>
		<Size>
			<CX>320</CX>
			<CY>25</CY>
		</Size>
		<TextColor>
				<R>255</R>
				<G>255</G>
				<B>255</B>
		</TextColor>
	</Editbox>
	<Screen item = "NR_YESNO_Box">
		<ScreenID>NR_Box</ScreenID>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<LeftAnchorOffset>130</LeftAnchorOffset>
		<TopAnchorOffset>130</TopAnchorOffset>
		<RightAnchorOffset>130</RightAnchorOffset>
		<BottomAnchorOffset>130</BottomAnchorOffset>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>

		<Text>Confirmation</Text>
		<Style_VScroll>false</Style_VScroll>
		<Style_HScroll>false</Style_HScroll>
		<Style_Transparent>false</Style_Transparent>
		<!--<TooltipReference/>-->
		<DrawTemplate>WDT_Stone</DrawTemplate>
		<Style_Titlebar>false</Style_Titlebar>
		<Style_Closebox>false</Style_Closebox>
		<Style_Minimizebox>false</Style_Minimizebox>
		<Style_Border>true</Style_Border>
		<Style_Sizable>false</Style_Sizable>
		<Pieces>NR_YESNO_YesButton</Pieces>
		<Pieces>NR_YESNO_NoButton</Pieces>
		<Pieces>NR_YESNO_Display</Pieces>
		<Pieces>NR_Name</Pieces>
	</Screen>

<!-- Used to obscure the backing window and prevent UI events from going through to it -->
	<Screen item = "NR_Dialog">
		<RelativePosition>true</RelativePosition>
		<Location>
			<X>0</X>
			<Y>0</Y>
		</Location>
		<Size>
			<CX>700</CX>
			<CY>500</CY>
		</Size>

		<Text></Text>
		<Style_VScroll>false</Style_VScroll>
		<Style_HScroll>false</Style_HScroll>
		<Style_Transparent>false</Style_Transparent>
		<!--<TooltipReference/>-->
		<DrawTemplate>WDT_Fade</DrawTemplate>
		<Style_Titlebar>false</Style_Titlebar>
		<Style_Closebox>false</Style_Closebox>
		<Style_Minimizebox>false</Style_Minimizebox>
		<Style_Border>false</Style_Border>
		<Style_Sizable>false</Style_Sizable>
		<Pieces>NR_YESNO_Box</Pieces>
	</Screen>
</XML>
